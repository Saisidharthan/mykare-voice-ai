# OpenAI (LLM)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini         # or gpt-4o

# Tavus (Avatar + Voice UI)
TAVUS_API_KEY=tavus-...
TAVUS_REPLICA_ID=r79e1c033f          # your Tavus replica ID
TAVUS_PERSONA_ID=                    # auto-created on first run if left blank

# Deepgram STT (optional — Tavus handles STT by default)
DEEPGRAM_API_KEY=

# Cartesia TTS (optional — set to use Cartesia voice inside Tavus)
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091

# Backend public URL (Tavus needs this to call your LLM endpoint)
PUBLIC_BACKEND_URL=https://your-backend.com

# Internal key Tavus will send as Bearer token to your /v1/chat/completions
LLM_INTERNAL_KEY=change-me-secret-key

# SQLite DB path
DB_PATH=./mykare.db
